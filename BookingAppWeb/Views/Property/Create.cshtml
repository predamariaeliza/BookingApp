@model BookingApp.Domain.Entities.Property

<div class="w-100 card border-0 p-4">

    @* titlul paginii "Create Property" *@
    <div class="card-header bg-success bg-gradient m-lg-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class"text-white py-2">Create Property</h2>
            </div>
        </div>
    </div>

    @* Lista valorilor de adaugat pentru noua proprietate *@
    <div class="card-body border p-4">
        <form method="post" class="row">

            <div class="p-3">

                @* ASP validations - ModelState from controllers*@
                <div asp-validation-summary="ModelOnly"></div>

                <div class="form-floating py-2 col-12">
                    <input asp-for="@Model.Name" class="form-control border shadow"/>
                    <label asp-for="Name" class="ms-2">Name</label>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="@Model.Description" class="form-control border shadow" />
                    <label asp-for="Description" class="ms-2">Description</label>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="@Model.Price" class="form-control border shadow" />
                    <label asp-for="Price" class="ms-2">Price</label>
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="@Model.SquareMeters" class="form-control border shadow" />
                    <label asp-for="SquareMeters" class="ms-2">Shttps://localhost:7171/quareMeters</label>
                    <span asp-validation-for="SquareMeters" class="text-danger"></span>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="@Model.Occupancy" class="form-control border shadow" />
                    <label asp-for="Occupancy" class="ms-2">Occupancy</label>
                    <span asp-validation-for="Occupancy" class="text-danger"></span>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="@Model.ImageUrl" class="form-control border shadow" />
                    <label asp-for="ImageUrl" class="ms-2">ImageUrl</label>
                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                </div>

                <div class="row pt-2">

                    @* Create button *@
                    <div class="col-6 col-md-3">
                        <button type="submit" class="btn btn-secondary w-100">
                            <i class="bi bi-check-circle"></i> Create
                        </button>
                    </div>

                    @* Cancel button => ma duce inapoi la pagina de Index*@
                    <div class="col-6 col-md-3">
                        <a asp-controller="Property" asp-action="Index" class="btn btn-secondary w-100">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>

                </div>

            </div>

        </form>
    </div>

</div>

@* added javascript document reference*@
@section Scripts{
@{
    <partial name="_ValidationScriptsPartial"/>
}
}