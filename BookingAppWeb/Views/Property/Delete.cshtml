@model Property

<div class="w-100 card border-0 p-4">

    @* titlul paginii "Create Property" *@
    <div class="card-header bg-success bg-gradient m-lg-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class"text-white py-2">Delete Property</h2>
            </div>
        </div>
    </div>

    @* Lista valorilor de adaugat pentru noua proprietate *@
    <div class="card-body border p-4">
        <form method="post" class="row">
            <input asp-for="Id" hidden />

            <div class="col-10">
                
                <div class="p-3">

                @* ASP validations - ModelState from controllers*@
                <div asp-validation-summary="All"></div>

                <div class="form-floating py-2 col-12">
                    <input asp-for="Name" disabled class="form-control border shadow" />
                    <label asp-for="Name" class="ms-2">Name</label>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Description" disabled class="form-control border shadow" />
                    <label asp-for="Description" class="ms-2">Description</label>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Price" disabled class="form-control border shadow" />
                    <label asp-for="Price" class="ms-2">Price</label>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="SquareMeters" disabled class="form-control border shadow" />
                    <label asp-for="SquareMeters" class="ms-2">SquareMeters</label>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Occupancy" disabled class="form-control border shadow" />
                    <label asp-for="Occupancy" class="ms-2">Occupancy</label>
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="ImageUrl" disabled class="form-control border shadow" />
                    <label asp-for="ImageUrl" class="ms-2">ImageUrl</label>
                </div>

                <div class="row pt-2">

                    @* Create button *@
                    <div class="col-6 col-md-3">
                        <button type="submit" class="btn btn-danger w-100">
                            <i class="bi bi-trash-fill"></i> Delete
                        </button>
                    </div>

                    @* Cancel button => ma duce inapoi la pagina de Index*@
                    <div class="col-6 col-md-3">
                        <a asp-controller="Property" asp-action="Index" class="btn btn-secondary w-100">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>

                </div>

            </div>
            
            </div>
            
            <div class="col-2">

                @*Imaginea Proprietatii(constructiei)*@
                <img src="@Model.ImageUrl" width="100%"
                     style=" border-radius:5px; border:1px solid #bbb9b9" />
            </div>

        </form>
    </div>

</div>

@* added javascript document reference*@
@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}